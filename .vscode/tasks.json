{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "extension: compile",
			"type": "shell",
			"command": "pnpm run compile",
			"options": {
				"cwd": "${workspaceFolder}/artifact/tile-builder-extension"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": [
				"$tsc"
			]
		}
	]
}
