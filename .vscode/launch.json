{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Run Extension",
			"type": "extensionHost",
			"request": "launch",
			"args": [
				"--extensionDevelopmentPath=${workspaceFolder}/artifact/tile-builder-extension"
			],
			"outFiles": [
				"${workspaceFolder}/artifact/tile-builder-extension/dist/**/*.js"
			],
			"preLaunchTask": "extension: compile"
		}
	]
}
